{
  "name": "fabsms-clarity",
  "displayName": "ClarityAI",
  "description": "Geração automática de README com IA local (Ollama) — 100% offline, sem envio de dados.",
  "version": "0.0.6",
  "publisher": "FabsMS",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FabsMS/Clarity-Extension"
  },
  "homepage": "https://github.com/FabsMS/Clarity-Extension#readme",
  "bugs": {
    "url": "https://github.com/FabsMS/Clarity-Extension/issues"
  },
  "keywords": [
    "documentation",
    "readme",
    "ai",
    "ollama",
    "python",
    "code analysis",
    "generator",
    "offline"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fabsms-clarity.generateDocumentation",
        "title": "Gerar Documentação com Clarity",
        "category": "Clarity"
      },
      {
        "command": "fabsms-clarity.setupEnvironment",
        "title": "Configurar Ambiente Python",
        "category": "Clarity"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2"
  }
}
